cancelado. Si deseas agendar una nueva cita, escribe agendar cita.\\\",\\n  \\\"session_id\\\": \\\"584142711347\\\",\\n  \\\"conversation_id\\\": \\\"7\\\",\\n  \\\"account_id\\\": \\\"1\\\",\\n  \\\"platform\\\": \\\"whatsapp\\\",\\n  \\\"has_image\\\": false,\\n  \\\"image_url\\\": null\\n}\",\"generationInfo\":{\"finish_reason\":\"stop\"}}]]},\"tokenUsage\":{\"completionTokens\":143,\"promptTokens\":9258,\"totalTokens\":9401}}}"}}
